terraform {
  required_version = ">= 1.6"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 6.0"
    }
  }
}

provider "google" {
  project = var.project_id
  region  = var.region

  # OIDC authentication via GitHub Actions Workload Identity Federation.
  # Locally, run: gcloud auth application-default login
}
